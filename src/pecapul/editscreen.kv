
<EditLessonScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size
            
    name: "edit_lesson"

    edit_lesson_list: id_edit_lesson_list
    edit_tag_list: id_edit_tag_list
    lesson_name: id_lesson_name

    BoxLayout:
        orientation: "horizontal"

        BoxLayout:
            orientation: "vertical"
            size_hint_x: 0.2
            padding: 20

            Widget:
                size_hint_y: 0.8
            
            Button:
                size_hint_y: None 
                height: 25
                text: "Import"
            
            Button:
                size_hint_y: None
                height: 25
                text: "Export"

        BoxLayout:
            orientation: "vertical"
            size_hint_x: 0.6

            Label:
                id: id_lesson_name
                size_hint_y: .1
                text: ""
                font_size: 24
                bold: True

            ScrollView:
                do_scroll_y: True
                do_scroll_x: False
                bar_width: 10
                scroll_type: ['bars', 'content']

                GridLayout:
                    id: id_edit_lesson_list
                    size_hint_y: .9
                    cols: 1
                    padding: 10
                    spacing: 10

        BoxLayout:
            orientation: "vertical"
            size_hint_x: 0.2
            padding: 20

            ScrollView:
                do_scroll_y: True
                do_scroll_x: False
                bar_width: 10
                scroll_type: ['bars', 'content']

                GridLayout:
                    id: id_edit_tag_list
                    size_hint_y: .9
                    cols: 1
                    padding: 10
                    spacing: 10

            Button:
                text: "Save"
                size_hint_y: None
                height: 25
                on_release: root.save_lesson()
            
            Button:
                text: "Cancel"
                size_hint_y: None
                height: 25
                on_release: root.cancel_lesson()

<EditTagBox>:
    
    orientation: "horizontal"
    text_tag: id_tag_text

    size_hint_y: None 
    height: 25

    Button:
        id: id_tag_text
        text: ""

<EditTermBox>:
    canvas.before:
        Color:
            rgba: .5, .5, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size

    orientation: "horizontal"
    label_from: id_lang_from_tag
    text_from: id_term_from_text

    label_to: id_lang_to_tag
    text_to: id_term_to_text

    size_hint_y: None 
    height: 25
    
    Label:
        id: id_lang_from_tag
        text: ""
        size_hint_x: .1
    TextInput:
        id: id_term_from_text
        text: ""
        size_hint_x: .4

    Label:
        id: id_lang_to_tag
        text: ""
        size_hint_x: .1

    TextInput:
        id: id_term_to_text
        text: ""
        size_hint_x: .4

<AddItemBox>:
    size_hint_y: None
    height: 25
    text: "+"
    font_size: 50
    bold: True
